{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "happyyein",
  "compatibility_date": "2026-04-07",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // Production D1/R2: Configure bindings via Cloudflare Dashboard > Pages > Settings > Functions
  // Or add real database_id here after: npx wrangler d1 create yein-dental-db
  // Local dev uses: --d1=yein-dental-db --r2=yein-dental-images --local
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "yein-dental-db",
      "database_id": "00671886-3f10-49d2-8731-6766e944223e"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "yein-dental-images"
    }
  ]
  // 자동 블로그: 매일 오전 7시(KST) 자동 발행
  // Cloudflare Pages는 cron trigger 미지원 → GitHub Actions 스케줄러로 매일 호출
  // POST https://happyyein.pages.dev/api/auto-blog/generate (Authorization: Bearer AUTO_BLOG_SECRET)
  // Production secrets: wrangler pages secret put OPENAI_API_KEY / AUTO_BLOG_SECRET
}
