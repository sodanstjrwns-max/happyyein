{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "yein-dental",
  "compatibility_date": "2026-04-07",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "yein-dental-db",
      "database_id": "local-dev"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "yein-dental-images"
    }
  ]
}
